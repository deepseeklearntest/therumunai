# Base URL of the deployed API Gateway stage that fronts services/submit.
# In production this points at the real API Gateway invoke URL, e.g.
#   NEXT_PUBLIC_API_BASE_URL=https://abc123.execute-api.ap-south-1.amazonaws.com
# For local development against a local/mock backend, use:
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
